{
  "name": "copy-to",
  "displayName": "Copy to",
  "description": "Copy selected files/folders to a configurable destination from File Explorer context menu",
  "version": "0.1.0",
  "publisher": "laststance",
  "license": "ISC",
  "keywords": [
    "copy",
    "file",
    "folder",
    "explorer",
    "context menu"
  ],
  "files": [
    "dist",
    "images/icon.png",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/laststance/copy-to"
  },
  "homepage": "https://github.com/laststance/copy-to#readme",
  "bugs": {
    "url": "https://github.com/laststance/copy-to/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "images/icon.png",
  "activationEvents": [
    "onCommand:copy-to.copyToDestination",
    "onCommand:copy-to.copyToPreset1",
    "onCommand:copy-to.copyToPreset2",
    "onCommand:copy-to.copyToPreset3",
    "onCommand:copy-to.copyToPreset4",
    "onCommand:copy-to.copyToPreset5",
    "onCommand:copy-to.copyToPreset6",
    "onCommand:copy-to.copyToPreset7",
    "onCommand:copy-to.copyToPreset8"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copy-to.copyToDestination",
        "title": "Copy to...",
        "shortTitle": "Browse..."
      },
      {
        "command": "copy-to.copyToPreset1",
        "title": "Copy to Preset 1"
      },
      {
        "command": "copy-to.copyToPreset2",
        "title": "Copy to Preset 2"
      },
      {
        "command": "copy-to.copyToPreset3",
        "title": "Copy to Preset 3"
      },
      {
        "command": "copy-to.copyToPreset4",
        "title": "Copy to Preset 4"
      },
      {
        "command": "copy-to.copyToPreset5",
        "title": "Copy to Preset 5"
      },
      {
        "command": "copy-to.copyToPreset6",
        "title": "Copy to Preset 6"
      },
      {
        "command": "copy-to.copyToPreset7",
        "title": "Copy to Preset 7"
      },
      {
        "command": "copy-to.copyToPreset8",
        "title": "Copy to Preset 8"
      }
    ],
    "submenus": [
      {
        "id": "copy-to.submenu",
        "label": "Copy to..."
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "submenu": "copy-to.submenu",
          "when": "explorerResourceIsFolder || !explorerResourceIsRoot",
          "group": "7_modification"
        }
      ],
      "copy-to.submenu": [
        {
          "command": "copy-to.copyToPreset1",
          "when": "copyTo.preset1Configured",
          "group": "1_presets@1"
        },
        {
          "command": "copy-to.copyToPreset2",
          "when": "copyTo.preset2Configured",
          "group": "1_presets@2"
        },
        {
          "command": "copy-to.copyToPreset3",
          "when": "copyTo.preset3Configured",
          "group": "1_presets@3"
        },
        {
          "command": "copy-to.copyToPreset4",
          "when": "copyTo.preset4Configured",
          "group": "1_presets@4"
        },
        {
          "command": "copy-to.copyToPreset5",
          "when": "copyTo.preset5Configured",
          "group": "1_presets@5"
        },
        {
          "command": "copy-to.copyToPreset6",
          "when": "copyTo.preset6Configured",
          "group": "1_presets@6"
        },
        {
          "command": "copy-to.copyToPreset7",
          "when": "copyTo.preset7Configured",
          "group": "1_presets@7"
        },
        {
          "command": "copy-to.copyToPreset8",
          "when": "copyTo.preset8Configured",
          "group": "1_presets@8"
        },
        {
          "command": "copy-to.copyToDestination",
          "group": "2_browse@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "copy-to.copyToPreset1",
        "key": "ctrl+shift+c 1",
        "mac": "cmd+shift+c 1",
        "when": "explorerViewletFocus"
      },
      {
        "command": "copy-to.copyToPreset2",
        "key": "ctrl+shift+c 2",
        "mac": "cmd+shift+c 2",
        "when": "explorerViewletFocus"
      },
      {
        "command": "copy-to.copyToPreset3",
        "key": "ctrl+shift+c 3",
        "mac": "cmd+shift+c 3",
        "when": "explorerViewletFocus"
      },
      {
        "command": "copy-to.copyToPreset4",
        "key": "ctrl+shift+c 4",
        "mac": "cmd+shift+c 4",
        "when": "explorerViewletFocus"
      },
      {
        "command": "copy-to.copyToPreset5",
        "key": "ctrl+shift+c 5",
        "mac": "cmd+shift+c 5",
        "when": "explorerViewletFocus"
      },
      {
        "command": "copy-to.copyToPreset6",
        "key": "ctrl+shift+c 6",
        "mac": "cmd+shift+c 6",
        "when": "explorerViewletFocus"
      },
      {
        "command": "copy-to.copyToPreset7",
        "key": "ctrl+shift+c 7",
        "mac": "cmd+shift+c 7",
        "when": "explorerViewletFocus"
      },
      {
        "command": "copy-to.copyToPreset8",
        "key": "ctrl+shift+c 8",
        "mac": "cmd+shift+c 8",
        "when": "explorerViewletFocus"
      }
    ],
    "configuration": {
      "title": "Copy to",
      "properties": {
        "copyTo.destinationPath": {
          "type": "string",
          "default": "",
          "description": "The destination directory path for copied files. Supports ~ for home directory (e.g., ~/utils). Leave empty to be prompted each time."
        },
        "copyTo.presets": {
          "type": "array",
          "maxItems": 8,
          "default": [],
          "markdownDescription": "Favorite destination directories (up to 8). Each preset appears in the context menu and can be triggered via keyboard shortcut.\n\nExample:\n```json\n[\n  { \"label\": \"Downloads\", \"path\": \"~/Downloads\" },\n  { \"label\": \"Components\", \"path\": \"~/projects/src/components\" }\n]\n```",
          "items": {
            "type": "object",
            "required": [
              "label",
              "path"
            ],
            "properties": {
              "label": {
                "type": "string",
                "description": "Display name for this preset (e.g., 'Downloads', 'Components')"
              },
              "path": {
                "type": "string",
                "description": "Destination path. Supports ~ for home directory"
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run build",
    "build": "node esbuild.config.mjs --production",
    "watch": "node esbuild.config.mjs --watch",
    "lint": "tsc --noEmit",
    "prepare": "husky",
    "prettier": "prettier --ignore-unknown --write ."
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.23.0",
  "lint-staged": {
    "*": "prettier --ignore-unknown --write"
  }
}
